{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaestral",
  "version": "0.0.1",
  "identifier": "dev.kaestral.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run bundle:server && node scripts/prepare-resources.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Kaestral",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
